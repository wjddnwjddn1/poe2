# GERSON UPDATE NOTE
# - Updated from: 0.5 Binu Quarterstaff Strict Endgame.filter
# - Kept CustomAlertSound filenames on the old Gerson 백업/sounds/... set.
# - Quarterstaff typo in the source override was corrected from Quaterstaves to Quarterstaves.
#===============================================================================================================
#===============================================================================================================
# [WELCOME] TABLE OF CONTENTS + QUICKJUMP TABLE
#===============================================================================================================
# [[0100]] OVERRIDE AREA 1 - Override ALL rules here
#===============================================================================================================
# GERSON LEGACY SOUND OVERRIDES - restored from old 거슨필터
#===============================================================================================================

Show
    Rarity Normal
    BaseType  "Rattling Sceptre" "Gemini Crossbow" "Siege Crossbow" "Desolate Crossbow" "Massive Greathammer" "Tawhoan Greatclub" "Bolting Quarterstaff" "Sleek Jacket" "Slipstrike Vest" "Vile Robe" "Amethyst Ring" "Prismatic Ring" "Breach Ring" "Gold Amulet" "Solar Amulet" "Stellar Amulet"
    ItemLevel > 81
    SetTextColor 255 255 255
    SetBorderColor 107 107 107
    SetTextColor 255 255 255
    SetFontSize 45
    CustomAlertSound "sounds/b1.mp3" 150
    MinimapIcon 2 Orange Diamond
    PlayEffect White 1

Show
    Rarity Normal
    BaseType  "Reaping Staff" "Dueling Wand" "Chiming Staff"
    ItemLevel > 81
    SetTextColor 255 255 255
    SetBorderColor 68 68 68
    SetTextColor 255 255 255
    SetFontSize 45
    CustomAlertSound "sounds/b1.mp3" 150
    MinimapIcon 2 Orange Diamond
    PlayEffect White 1

Show 
    Rarity Rare
	UnidentifiedItemTier >= 3
    SetBorderColor 255 12 12
    MinimapIcon 2 Orange Diamond
    SetTextColor 247 214 68
    CustomAlertSound "sounds/b1.mp3" 90
    SetBackgroundColor 7 5 4

Show 
    Rarity Magic
	UnidentifiedItemTier >= 3
    SetTextColor 15 27 53
    SetBorderColor 48 12 255
    SetTextColor 255 255 255
    MinimapIcon 2 Orange Diamond
    CustomAlertSound "sounds/b1.mp3" 90
    SetBackgroundColor 74 124 231

# GERSON: Middle jewellery safety net - area 79+, tier 2+ visual-only.
Show
    Rarity >= Magic
    Rarity <= Rare
    AreaLevel >= 79
    UnidentifiedItemTier >= 2
    Class == "Amulets" "Belts" "Rings" "Talismans"
    SetFontSize 38
    SetTextColor 255 245 190 255
    SetBorderColor 210 175 90 255
    SetBackgroundColor 28 22 10 210
    MinimapIcon 2 Yellow Diamond

# GERSON: Hide rare gear/jewellery below unidentified tier 3 in area 79+ - 2026-06-06.
Hide
    Rarity Rare
    AreaLevel >= 79
    Class == "Amulets" "Belts" "Body Armours" "Boots" "Bows" "Bucklers" "Charms" "Crossbows" "Foci" "Gloves" "Helmets" "Jewels" "Life Flasks" "Mana Flasks" "One Hand Maces" "Quarterstaves" "Quivers" "Rings" "Sceptres" "Shields" "Spears" "Staves" "Talismans" "Two Hand Maces" "Wands"
    SetFontSize 18
    SetBackgroundColor 20 20 0 0

# GERSON: Hide magic gear/jewellery below unidentified tier 3 in area 79+ - 2026-06-06.
Hide
    Rarity Magic
    AreaLevel >= 79
    Class == "Amulets" "Belts" "Body Armours" "Boots" "Bows" "Bucklers" "Charms" "Crossbows" "Foci" "Gloves" "Helmets" "Jewels" "Life Flasks" "Mana Flasks" "One Hand Maces" "Quarterstaves" "Quivers" "Rings" "Sceptres" "Shields" "Spears" "Staves" "Talismans" "Two Hand Maces" "Wands"
    SetFontSize 18
    SetBackgroundColor 20 20 0 0

Show
    Corrupted False
	Sockets >= 3
	Class == "Body Armours" "Bows" "Crossbows" "Quarterstaves" "Staves" "Two Hand Maces"
    SetBorderColor 255 12 12
    MinimapIcon 2 Blue Star
    CustomAlertSound "sounds/mariolvlup.mp3" 150
    PlayEffect White

Show
    Corrupted False
    Sockets >= 2
    Class == "Boots" "Bucklers" "Foci" "Gloves" "Helmets" "One Hand Maces" "Sceptres" "Shields" "Spears" "Wands"
