#Hide  # $type->endgame->conditionalhiders->crafting $tier->arhider !utility_minimize
#	Sockets 0
#	Quality 0
#	UnidentifiedItemTier <= 3
#	BaseEnergyShield 0
#	BaseEvasion 0
#	BaseArmour > 0
